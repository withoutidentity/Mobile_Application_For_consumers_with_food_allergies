generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ระดับความรุนแรงของอาการแพ้
enum Severity {
  LOW
  MEDIUM
  HIGH
}

// บทบาทของผู้ใช้
enum Role {
  USER
  ADMIN
}

model User {
  id                   Int             @id @default(autoincrement())
  email                String          @unique
  password             String
  name                 String
  role                 Role            @default(USER)
  dietaryRestrictions  String[]        // เช่น มังสวิรัติ, คีโต, เจ
  emergencyContact     String?
  allergies            UserAllergy[]   // ความสัมพันธ์กับสารก่อภูมิแพ้
  histories            ScanHistory[]   // ประวัติการสแกนสินค้า
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  refreshToken         String?

  @@map("users")
}

model Allergen {
  id              Int                 @id @default(autoincrement())
  name            String              // ชื่อสารก่อภูมิแพ้ (ไทย)
  altNames        String[]            // ชื่ออื่นๆ เช่น Peanut, Gluten, Shrimp
  description     String?             // คำอธิบายเพิ่มเติม
  defaultLevel    Severity            // ระดับความรุนแรงโดยทั่วไป
  products        ProductAllergen[]   // ความสัมพันธ์กับสินค้า
  users           UserAllergy[]       // ผู้ใช้ที่แพ้สารนี้
  symptoms        AllergenSymptom?    // ความสัมพันธ์กับตารางอาการ

  @@map("allergens")
}

model AllergenSymptom {
  id              Int        @id @default(autoincrement())
  allergenId      Int        @unique
  allergen        Allergen   @relation(fields: [allergenId], references: [id], onDelete: Cascade)
  symptoms        String[]   // อาการเมื่อได้รับสารนี้ เช่น คัน ผื่น หายใจลำบาก
  firstAid        String[]   // วิธีปฐมพยาบาลเบื้องต้น
  whenToSeekHelp  String[]   // เมื่อใดควรไปโรงพยาบาล

  @@map("allergen_symptoms")
}

model Product {
  id              Int                 @id @default(autoincrement())
  barcode         String              @unique
  name            String
  brand           String?
  category        String?
  imageUrl        String?
  ingredients     String[]            // ส่วนประกอบทั้งหมด
  allergens       ProductAllergen[]   // ความสัมพันธ์กับสารก่อภูมิแพ้
  histories       ScanHistory[]       // ประวัติการสแกน
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("products")
}

model ProductAllergen {
  id              Int        @id @default(autoincrement())
  productId       Int
  allergenId      Int
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  allergen        Allergen   @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@map("product_allergens")
}

model UserAllergy {
  id              Int        @id @default(autoincrement())
  userId          Int
  allergenId      Int
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergen        Allergen   @relation(fields: [allergenId], references: [id], onDelete: Cascade)
  severity        Severity   // ระดับความรุนแรงที่ผู้ใช้ระบุเอง (เฉพาะบุคคล)

  @@unique([userId, allergenId])
  @@map("user_allergies")
}

model ScanHistory {
  id              Int        @id @default(autoincrement())
  userId          Int
  productId       Int
  scannedAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("scan_histories")
}
